OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Browser
HEADLESS=0
SLOW_MO_MS=100
MAX_STEPS=60
HARD_MAX_STEPS=120
STEP_EXTENSION=20
COMPACT_EVERY_STEPS=16
KEEP_BROWSER_OPEN=1
STARTUP_HELPER_TIMEOUT=30
ALLOW_EXTERNAL_SEARCH=0
TRACE_DIR=.agent_runs
PERSIST_SESSION=0

# After this many "no action" rounds, force finish if evaluator already set ready_to_finish
STALL_FORCE_FINISH=2

# Use system Chrome instead of Chromium (1=yes)
USE_CHROME=0

# Chrome user data dir (leave empty for clean temp profile)
# Chrome user data dir for persistent sessions, for example:
# C:\Users\Самурай\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE=
# Chrome profile directory inside the user data dir, for example:
# Default
# Profile 1
CHROME_PROFILE_DIRECTORY=
